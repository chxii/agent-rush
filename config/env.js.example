// Local direct-to-GLM development config.
// Copy this file to config/env.js and fill in your real GLM API key.
// config/env.js is listed in .gitignore and must not be committed.
// Leave LLM_PROXY_URL unset locally to call GLM directly from the browser.
// Production uses config/env.prod.js + Vercel environment variables instead;
// never put a real key in env.prod.js or any tracked file.
window.GLM_API_KEY = 'YOUR_GLM_API_KEY_HERE'
window.GLM_BASE_URL = 'https://api.z.ai/api/coding/paas/v4'
window.GLM_MODEL = 'glm-5.1'
