{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExecutorSchemas",
  "description": "Agent Rush Executor schemas for A4 semi-loop decisions.",
  "definitions": {
    "CardId": {
      "type": "string"
    },
    "CardStatus": {
      "type": "string",
      "enum": ["pending", "in_progress", "success", "failed", "abandoned", "replaced"]
    },
    "ActionType": {
      "type": "string",
      "enum": ["fetch_prices", "broadcast_tx", "replace_tx", "monitor_mempool", "scan_replacement", "abandon_card", "reallocate_gas"]
    },
    "IncidentAction": {
      "type": "string",
      "enum": ["continue", "retry_broadcast", "replace_tx", "abandon_card", "reallocate_gas", "skip_card"]
    },
    "EventType": {
      "type": "string",
      "enum": ["target_stolen", "tx_failed", "gas_insufficient", "player_intervention", "target_invalid"]
    },
    "CardParam": {
      "type": "object",
      "required": ["id", "type", "expectedProfit", "gasBudget", "riskRating", "timeWindowSec"],
      "additionalProperties": true,
      "properties": {
        "id": { "$ref": "#/definitions/CardId" },
        "type": { "type": "string" },
        "expectedProfit": { "type": "number" },
        "gasBudget": { "type": "integer", "minimum": 0 },
        "riskRating": { "type": "number", "minimum": 0, "maximum": 1 },
        "timeWindowSec": { "type": "integer", "minimum": 1 }
      }
    },
    "GasAllocation": {
      "type": "object",
      "required": ["cardId", "gas"],
      "additionalProperties": false,
      "properties": {
        "cardId": { "$ref": "#/definitions/CardId" },
        "gas": { "type": "integer", "minimum": 0 }
      }
    },
    "CompletedCard": {
      "type": "object",
      "required": ["id", "status", "actualProfit", "gasUsed"],
      "additionalProperties": true,
      "properties": {
        "id": { "$ref": "#/definitions/CardId" },
        "status": { "$ref": "#/definitions/CardStatus" },
        "actualProfit": { "type": "number" },
        "gasUsed": { "type": "integer", "minimum": 0 }
      }
    },
    "CardStatusSnapshot": {
      "type": "object",
      "required": ["id", "status", "allocatedGas", "gasUsed", "actualProfit"],
      "additionalProperties": true,
      "properties": {
        "id": { "$ref": "#/definitions/CardId" },
        "type": { "type": "string" },
        "status": { "$ref": "#/definitions/CardStatus" },
        "allocatedGas": { "type": "integer", "minimum": 0 },
        "gasUsed": { "type": "integer", "minimum": 0 },
        "actualProfit": { "type": "number" }
      }
    },
    "SceneInfo": {
      "type": "object",
      "required": ["sceneType", "layer", "enemyBotActivity"],
      "additionalProperties": true,
      "properties": {
        "sceneType": { "type": "string" },
        "layer": { "type": "integer", "minimum": 1, "maximum": 20 },
        "enemyBotActivity": { "type": "string", "enum": ["none", "low", "medium", "high"] }
      }
    },
    "ExecutionLogEntry": {
      "type": "object",
      "required": ["timestampMs"],
      "additionalProperties": true,
      "properties": {
        "timestampMs": { "type": "integer" },
        "cardId": { "$ref": "#/definitions/CardId" },
        "action": { "$ref": "#/definitions/ActionType" },
        "input": { "type": "object", "additionalProperties": true },
        "output": { "type": "object", "additionalProperties": true },
        "success": { "type": "boolean" },
        "incident": { "type": "boolean" }
      }
    },
    "DecisionHighlight": {
      "type": "object",
      "required": ["momentLabel", "description"],
      "additionalProperties": false,
      "properties": {
        "momentLabel": {
          "type": "string",
          "enum": ["task_decomposition", "multi_step_planning", "tool_call", "iterative_repair", "workflow_closure"]
        },
        "description": { "type": "string" }
      }
    }
  },
  "调用1_InitialPlanning": {
    "description": "Initial semi-loop ordering. Gas is player-owned and must not be emitted.",
    "input": {
      "type": "object",
      "required": ["cards", "totalGasPool", "scene", "remainingTimeWindowSec", "battlePlan"],
      "additionalProperties": true,
      "properties": {
        "cards": { "type": "array", "items": { "$ref": "#/definitions/CardParam" }, "minItems": 1, "maxItems": 4 },
        "totalGasPool": { "type": "integer", "minimum": 0 },
        "scene": { "$ref": "#/definitions/SceneInfo" },
        "remainingTimeWindowSec": { "type": "integer", "minimum": 0 },
        "battlePlan": { "type": "object", "additionalProperties": true }
      }
    },
    "output": {
      "type": "object",
      "required": ["reasoning", "executionOrder"],
      "additionalProperties": false,
      "properties": {
        "reasoning": { "type": "string" },
        "executionOrder": { "type": "array", "items": { "$ref": "#/definitions/CardId" } }
      }
    }
  },
  "调用2_SingleCardPlan": {
    "description": "Narrow single next-action decision. This replaces the old multi-step steps array.",
    "input": {
      "type": "object",
      "required": ["card", "allocatedGas", "remainingGasPool", "completedCards"],
      "additionalProperties": true,
      "properties": {
        "card": { "$ref": "#/definitions/CardParam" },
        "allocatedGas": { "type": "integer", "minimum": 0 },
        "remainingGasPool": { "type": "integer", "minimum": 0 },
        "completedCards": { "type": "array", "items": { "$ref": "#/definitions/CompletedCard" } }
      }
    },
    "output": {
      "type": "object",
      "required": ["reasoning", "action"],
      "additionalProperties": false,
      "properties": {
        "reasoning": { "type": "string" },
        "action": { "$ref": "#/definitions/ActionType" },
        "params": { "type": "object", "additionalProperties": true }
      }
    }
  },
  "调用3_IncidentResponse": {
    "description": "Narrow replan output for one incident.",
    "input": {
      "type": "object",
      "required": ["event", "affectedCardId", "remainingGasPool", "allCardStatuses", "trigger", "playerContingency"],
      "additionalProperties": true,
      "properties": {
        "event": { "$ref": "#/definitions/EventType" },
        "affectedCardId": { "$ref": "#/definitions/CardId" },
        "remainingGasPool": { "type": "integer", "minimum": 0 },
        "allCardStatuses": { "type": "array", "items": { "$ref": "#/definitions/CardStatusSnapshot" } },
        "trigger": { "type": "object", "additionalProperties": true },
        "playerContingency": { "type": "string", "enum": ["fight", "abandon", "transfer"] },
        "competitors": { "type": "object", "additionalProperties": true },
        "playerInstruction": { "type": ["string", "null"] }
      }
    },
    "output": {
      "type": "object",
      "required": ["reasoning", "action"],
      "additionalProperties": false,
      "properties": {
        "reasoning": { "type": "string" },
        "action": { "$ref": "#/definitions/IncidentAction" },
        "targetCardId": { "$ref": "#/definitions/CardId" },
        "gas": { "type": "integer", "minimum": 0 },
        "gasAllocations": { "type": "array", "items": { "$ref": "#/definitions/GasAllocation" } },
        "updatedExecutionOrder": { "type": "array", "items": { "$ref": "#/definitions/CardId" } }
      }
    }
  },
  "调用4_PlayerIntervention": {
    "description": "Reserved for A5. A4 only preserves the schema hook.",
    "input": {
      "type": "object",
      "required": ["playerInstruction", "currentExecutionState"],
      "additionalProperties": true,
      "properties": {
        "playerInstruction": { "type": "string" },
        "currentExecutionState": { "type": "object", "additionalProperties": true }
      }
    },
    "output": {
      "type": "object",
      "required": ["reasoning", "interpretedIntent", "updatedGasAllocations", "updatedExecutionOrder"],
      "additionalProperties": false,
      "properties": {
        "reasoning": { "type": "string" },
        "interpretedIntent": { "type": "string" },
        "updatedGasAllocations": { "type": "array", "items": { "$ref": "#/definitions/GasAllocation" } },
        "updatedExecutionOrder": { "type": "array", "items": { "$ref": "#/definitions/CardId" } }
      }
    }
  },
  "调用5_SettlementReport": {
    "description": "Round settlement report.",
    "input": {
      "type": "object",
      "required": ["completedCards", "executionLog", "totalGasUsed", "initialGasPool"],
      "additionalProperties": true,
      "properties": {
        "completedCards": { "type": "array", "items": { "$ref": "#/definitions/CompletedCard" } },
        "executionLog": { "type": "array", "items": { "$ref": "#/definitions/ExecutionLogEntry" } },
        "totalGasUsed": { "type": "integer", "minimum": 0 },
        "initialGasPool": { "type": "integer", "minimum": 0 }
      }
    },
    "output": {
      "type": "object",
      "required": ["reasoning", "summary", "netProfit", "decisionHighlights"],
      "additionalProperties": false,
      "properties": {
        "reasoning": { "type": "string" },
        "summary": { "type": "string" },
        "netProfit": { "type": "number" },
        "decisionHighlights": {
          "type": "array",
          "items": { "$ref": "#/definitions/DecisionHighlight" },
          "minItems": 1,
          "maxItems": 5
        }
      }
    }
  }
}
